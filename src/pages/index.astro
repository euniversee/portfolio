---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
  title="Sigit — Portfolio"
  description="Multi-disciplinary Engineer, Developer & Designer"
>
  <div class="topbar">
    <div class="url-bar">
      <img src="/favicon.svg" alt="Logo" class="top-logo" />
      <span>Sigit — Portfolio</span>
    </div>
  </div>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-avatar-row">
      <div class="hero-avatar">
        <img
          src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774691961/1774691497942_jowtnl.jpg"
          alt="Sigit"
        />
      </div>
    </div>
    <h1>
      Hi I'm <em>Sigit</em> — I'm a Multi-disciplinary Engineer, Developer &amp; Designer.
      <span class="muted">Freshly graduated from Padjadjaran University.</span>
    </h1>
    <p class="hero-sub">
      A multi-disciplinary engineer, developer, and designer with experience in
      machine learning, visual branding, and building impactful full-stack web
      solutions.
    </p>
    <div class="social-row">
      <a
        class="social-link"
        href="https://instagram.com/sssgtdn.png"
        target="_blank"
        rel="noopener"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          ><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle
            cx="12"
            cy="12"
            r="4"></circle><circle
            cx="17.5"
            cy="6.5"
            r="0.5"
            fill="currentColor"
            stroke="none"></circle></svg
        >
        sssgtdn.png
      </a>
      <a
        class="social-link"
        href="https://github.com/euniversee"
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 2C6.477 2 2 6.484 2 12.021c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.444 22 12.021 22 6.484 17.523 2 12 2z"
          ></path></svg
        >
        euniversee
      </a>
      <a
        class="social-link"
        href="https://linkedin.com/in/sigitdwi"
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path></svg
        >
        sigitdwi
      </a>
      <span class="badge-avail"
        ><span class="dot"></span>Available for Work</span
      >
    </div>
  </div>

  <!-- BENTO: MAIN INFO CARDS -->
  <div class="bento">
    <!-- EXPERIENCE -->
    <div class="card exp-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="2" y="7" width="20" height="14" rx="2"></rect><path
              d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"></path></svg
          >
          Experience
        </div>
        <div class="timeline">
          <div class="tl-item">
            <div class="tl-year">2025</div>
            <div class="tl-co">Habibi Garden</div>
            <div class="tl-role">Software Developer (Internship)</div>
          </div>
          <div class="tl-item">
            <div class="tl-year">2025</div>
            <div class="tl-co">Ikatan Mahasiswa Berprestasi Wonogiri</div>
            <div class="tl-role">
              Full-Stack Web Developer &amp; Social Media Team
            </div>
          </div>
          <div class="tl-item">
            <div class="tl-year">2024</div>
            <div class="tl-co">Padjadjaran University</div>
            <div class="tl-role">Assistant Lecturer</div>
          </div>
          <div class="tl-item">
            <div class="tl-year">2023</div>
            <div class="tl-co">Padjadjaran University</div>
            <div class="tl-role">Design Division (Organizing Committee)</div>
          </div>
        </div>
      </div>
    </div>

    <!-- LISTENING (Larger Album Art) -->
    <div class="card listen-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"
            ></circle><circle cx="18" cy="16" r="3"></circle></svg
          >
          What I'm listening
        </div>
        <div class="listen-inner">
          <div class="album-art">
            <img
              src="https://t2.genius.com/unsafe/387x387/https%3A%2F%2Fimages.genius.com%2Fa2a3e14697c360bbcdab89c90a76cfac.1000x1000x1.png"
              alt="A Sorrowful Reunion"
            />
          </div>
          <div class="listen-info">
            <div class="listen-title">A Sorrowful Reunion</div>
            <div class="listen-artist">Reality Club</div>
            <div class="progress-bar" id="progressBar">
              <div class="progress-fill" id="progressFill"></div>
            </div>
            <div class="audio-controls">
              <div class="ctrl-row">
                <button class="ctrl-btn" id="seekBack"
                  ><svg viewBox="0 0 24 24" fill="currentColor"
                    ><polygon points="19 20 9 12 19 4 19 20"></polygon><rect
                      x="5"
                      y="4"
                      width="2"
                      height="16"></rect></svg
                  ></button
                >
                <button class="ctrl-btn" id="playPauseBtn">
                  <svg id="playIcon" viewBox="0 0 24 24" fill="currentColor"
                    ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
                  >
                  <svg
                    id="pauseIcon"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    style="display:none;"
                    ><rect x="6" y="4" width="4" height="16"></rect><rect
                      x="14"
                      y="4"
                      width="4"
                      height="16"></rect></svg
                  >
                </button>
                <button class="ctrl-btn" id="seekFwd"
                  ><svg viewBox="0 0 24 24" fill="currentColor"
                    ><polygon points="5 4 15 12 5 20 5 4"></polygon><rect
                      x="17"
                      y="4"
                      width="2"
                      height="16"></rect></svg
                  ></button
                >
              </div>
              <span class="ctrl-time" id="audioTime">0:00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- READING -->
    <div class="card reading-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"></path><path
              d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"></path></svg
          >
          What I'm reading
        </div>
        <div class="book-row">
          <div class="book-cover">
            <img
              src="https://m.media-amazon.com/images/S/compressed.photo.goodreads.com/books/1654371463i/18144590.jpg"
              alt="The Alchemist"
            />
          </div>
          <div class="book-info">
            <h4>The Alchemist</h4>
            <span>Paulo Coelho</span>
          </div>
        </div>
      </div>
    </div>

    <!-- MAP / LOCATION (OpenStreetMap Bandung) -->
    <div class="card map-card">
      <div class="map-bg">
        <iframe
          title="Bandung Map"
          src="https://www.openstreetmap.org/export/embed.html?bbox=107.55,-6.97,107.69,-6.86&layer=mapnik"
          loading="lazy"></iframe>
      </div>
      <div class="map-overlay-gradient"></div>
      <div class="map-pin">
        <div class="map-pin-inner"></div>
      </div>
      <div class="map-label">Bandung, ID</div>
    </div>

    <!-- CYCLING (Autoplay Video) -->
    <div
      class="card cycling-card"
      data-video-src="https://res.cloudinary.com/dad4b97rw/video/upload/v1774690340/PXL_20260323_002216611_5_iw6vz8.mp4"
    >
      <div class="cycling-bg">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          src="https://res.cloudinary.com/dad4b97rw/video/upload/q_auto:low,w_480/v1774690340/PXL_20260323_002216611_5_iw6vz8.mp4"
        ></video>
      </div>
      <div class="cycling-overlay"></div>
      <div class="cycling-label"><span>🚴</span> I love cycling</div>
    </div>

    <!-- TIME -->
    <div class="card time-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="12" cy="12" r="10"></circle><polyline
              points="12 6 12 12 16 14"></polyline></svg
          >
          Local Time
        </div>
        <div class="time-display" id="clockDisplay">--:--</div>
        <div class="time-sub">WIB · UTC+7</div>
        <div class="time-date" id="dateDisplay"></div>
      </div>
    </div>

    <!-- CALENDAR -->
    <div class="card calendar-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="3" y="4" width="18" height="18" rx="2"></rect><line
              x1="16"
              y1="2"
              x2="16"
              y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
              x1="3"
              y1="10"
              x2="21"
              y2="10"></line></svg
          >
          Calendar
        </div>
        <div class="cal-month" id="calMonth"></div>
        <div class="cal-grid" id="calGrid"></div>
      </div>
    </div>
  </div>

  <!-- MOTION SECTION -->
  <div class="section-row">
    <h2>Motion &amp; Post-Production</h2>
    <div class="line"></div>
    <span class="sub">Video Editing</span>
  </div>
  <div class="bento">
    <!-- FEATURED VIDEO -->
    <div class="card vid-featured">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
          >
          Featured work
        </div>
        <a
          class="video-thumb"
          href="https://www.youtube.com/watch?v=M8SstG8caqA"
          target="_blank"
          rel="noopener"
        >
          <img
            src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774683962/M8SstG8caqA-HD_r5gve9.jpg"
            alt="ICE 2025"
          />
          <div class="video-thumb-overlay"></div>
          <div class="overlay-play">
            <svg viewBox="0 0 10 12"
              ><polygon points="0,0 10,6 0,12"></polygon></svg
            >
          </div>
        </a>
        <div class="vid-title">
          After Movie — Imapres Campus Expo (ICE) 2025
        </div>
        <div class="vid-meta">Aftermovie · Documentary · 2:45</div>
        <div class="tool-chips">
          <span class="tool-chip">CapCut</span>
          <span class="tool-chip">Premiere Pro</span>
        </div>
      </div>
    </div>

    <!-- VIDEO LIST -->
    <div class="card vid-list-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="2" y="2" width="20" height="20" rx="3"></rect><path
              d="M10 8l6 4-6 4V8z"></path></svg
          >
          More projects
        </div>
        <div
          class="vid-item"
          data-video-src="https://res.cloudinary.com/dad4b97rw/video/upload/v1774686676/Bumper_bnpmt7.mp4"
          id="bumperVid"
        >
          <div class="vid-mini-thumb">
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686782/videoframe_5748_lp5cdi.png"
              alt="Bumper KKN"
            />
            <span class="vid-mini-play"
              ><svg viewBox="0 0 10 12"
                ><polygon points="0,0 10,6 0,12"></polygon></svg
              ></span
            >
          </div>
          <div>
            <div class="vid-item-title">Bumper Opening Aftermovie KKN</div>
            <div class="vid-item-dur">0:06 · Bumper</div>
          </div>
        </div>
        <a
          class="vid-item"
          href="https://www.instagram.com/sssgtdn/reels/"
          target="_blank"
          rel="noopener"
          style="text-decoration:none;"
        >
          <div
            class="vid-mini-thumb"
            style="background:#c85598;display:flex;align-items:center;justify-content:center;"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="rgba(255,255,255,0.85)"
              stroke-width="2"
              style="position:relative;z-index:1;"
              ><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle
                cx="12"
                cy="12"
                r="4"></circle></svg
            >
          </div>
          <div>
            <div class="vid-item-title">Reels Collection</div>
            <div class="vid-item-dur">Instagram · @sssgtdn</div>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- DESIGN SECTION -->
  <div class="section-row">
    <h2>Visual Design &amp; Branding</h2>
    <div class="line"></div>
    <span class="sub">UI / Graphic Design</span>
  </div>
  <div class="bento">
    <!-- DESIGN FEATURED -->
    <div class="card design-main">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M12 20h9"></path><path d="M16.5 3.5l4 4L7 21l-4 1 1-4z"
            ></path></svg
          >
          Featured project
        </div>
        <div
          class="design-img"
          data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/c_auto,h_900,w_1600/screenshot-1774687492892_zxn7lc.png"
          id="designFeaturedImg"
        >
          <img
            src="https://res.cloudinary.com/dad4b97rw/image/upload/c_auto,h_900,w_1600/screenshot-1774687492892_zxn7lc.png"
            alt="Kawula Store UI"
          />
        </div>
        <div class="vid-title">UI Design — Kawula Store</div>
        <div class="vid-meta">UI/UX Design · E-commerce · Web App</div>
        <div class="tool-chips" style="margin-top:10px;">
          <span class="tool-chip">Figma</span>
          <span class="tool-chip">Visual Studio Code</span>
        </div>
      </div>
    </div>

    <!-- GALLERY (renamed from Social Graphics) -->
    <div class="card sg-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle
              cx="8.5"
              cy="8.5"
              r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg
          >
          Gallery
        </div>
        <div class="sg-grid">
          <div
            class="sg-img"
            data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686648/1_biyys3.png"
            id="gallery1"
          >
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686648/1_biyys3.png"
              alt="Design 1"
            />
          </div>
          <div
            class="sg-img"
            data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686676/Copy_of_Sistem_Pengusir_Burung_Emprit_Lonchura_leucogastroides_Otomatis_Berbasis_Gelombang_Ultrasonik_Poster_A3_Portrait_1_aq8o7g.png"
            id="gallery2"
          >
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686676/Copy_of_Sistem_Pengusir_Burung_Emprit_Lonchura_leucogastroides_Otomatis_Berbasis_Gelombang_Ultrasonik_Poster_A3_Portrait_1_aq8o7g.png"
              alt="Design 2"
            />
          </div>
          <div
            class="sg-img"
            data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686680/Stop_Bullying_1080_x_1350_px_ddzkpd.png"
            id="gallery3"
          >
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686680/Stop_Bullying_1080_x_1350_px_ddzkpd.png"
              alt="Design 3"
            />
          </div>
          <div
            class="sg-img"
            data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686682/A_b_lhgith.png"
            id="gallery4"
          >
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686682/A_b_lhgith.png"
              alt="Design 4"
            />
          </div>
          <div
            class="sg-img wide"
            data-lightbox-src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686682/Terima_Kasih_jipx24.png"
            id="gallery5"
          >
            <img
              src="https://res.cloudinary.com/dad4b97rw/image/upload/v1774686682/Terima_Kasih_jipx24.png"
              alt="Design 5"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- WEB ENGINEERING SECTION -->
  <div class="section-row">
    <h2>Web Engineering</h2>
    <div class="line"></div>
    <span class="sub">Development</span>
  </div>
  <div class="bento">
    <div class="card webdev-list-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><polyline points="16 18 22 12 16 6"></polyline><polyline
              points="8 6 2 12 8 18"></polyline></svg
          >
          Projects
        </div>
        <a
          class="proj-item"
          href="https://www.kawula.store/"
          target="_blank"
          rel="noopener"
        >
          <div class="proj-left">
            <div class="proj-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"
                ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
                  d="M16 10a4 4 0 01-8 0"></path></svg
              >
            </div>
            <div>
              <div class="proj-name">Kawula Store — UMKM Giriwoyo</div>
              <div class="proj-stack">Next.js · TypeScript</div>
              <div class="proj-note">E-commerce · Shopping Platform</div>
            </div>
          </div>
          <span class="proj-arrow">↗</span>
        </a>
        <a
          class="proj-item"
          href="https://projectpkl-habibigarden.vercel.app/"
          target="_blank"
          rel="noopener"
        >
          <div class="proj-left">
            <div class="proj-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><rect x="2" y="3" width="20" height="14" rx="2"></rect><circle
                  cx="12"
                  cy="10"
                  r="3"></circle><path d="M8 17l4-4 4 4"></path></svg
              >
            </div>
            <div>
              <div class="proj-name">
                Real-time Tomato Ripeness Classification
              </div>
              <div class="proj-stack">Next.js · ngrok · Python (ML)</div>
              <div class="proj-note">
                Computer Vision · CNN · ML runs locally
              </div>
            </div>
          </div>
          <span class="proj-arrow">↗</span>
        </a>
        <a
          class="proj-item"
          href="https://euniversee.github.io/"
          target="_blank"
          rel="noopener"
        >
          <div class="proj-left">
            <div class="proj-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                ><circle cx="12" cy="8" r="4"></circle><path
                  d="M3 20c0-4 4-7 9-7s9 3 9 7"></path></svg
              >
            </div>
            <div>
              <div class="proj-name">
                Game Discovery App — Dicoding Submission
              </div>
              <div class="proj-stack">HTML · CSS · JavaScript</div>
              <div class="proj-note">Steam-inspired · Final Project</div>
            </div>
          </div>
          <span class="proj-arrow">↗</span>
        </a>
      </div>
    </div>

    <div class="card webdev-stack-card">
      <div class="card-inner">
        <div class="chip">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><polyline points="16 18 22 12 16 6"></polyline><polyline
              points="8 6 2 12 8 18"></polyline></svg
          >
          Stack
        </div>
        <div class="stack-grid">
          <span class="stack-tag">React</span>
          <span class="stack-tag">Next.js</span>
